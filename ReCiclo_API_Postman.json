          "name": "Criar novo item",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nomeItem\": \"Garrafa de Vidro\",\n  \"estadoItem\": \"Novo\",\n  \"tipoItem\": \"Vidro\",\n  \"localRetirada\": \"Rua A, 123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/items?doadorId=1",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "items"],
              "query": [
                {
                  "key": "doadorId",
                  "value": "1"
                }
              ]
            }
          }
        },
        {
          "name": "Atualizar item",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nomeItem\": \"Garrafa de Vidro Verde\",\n  \"estadoItem\": \"Usado\",\n  \"tipoItem\": \"Vidro\",\n  \"localRetirada\": \"Rua A, 123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/items/1?doadorId=1",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "items", "1"],
              "query": [
                {
                  "key": "doadorId",
                  "value": "1"
                }
              ]
            }
          }
        },
        {
          "name": "Deletar item",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/api/v1/items/1?doadorId=1",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "items", "1"],
              "query": [
                {
                  "key": "doadorId",
                  "value": "1"
                }
              ]
            }
          }
        }
      ]
    },
