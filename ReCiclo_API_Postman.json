{
  "info": {
    "name": "ReCiclo API REST",
    "description": "Coleção de testes para API REST ReCiclo",
    "version": "1.0.0"
  },
  "item": [
    {
      "name": "Autenticação",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"joao@example.com\",\n  \"senha\": \"senha123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Usuários",
      "item": [
        {
          "name": "Listar todos",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/usuarios",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "usuarios"]
            }
          }
        },
        {
          "name": "Obter por ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/usuarios/1",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "usuarios", "1"]
            }
          }
        },
        {
          "name": "Obter por Email",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/usuarios/email/joao@example.com",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "usuarios", "email", "joao@example.com"]
            }
          }
        },
        {
          "name": "Registrar novo usuário",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"João Silva\",\n  \"email\": \"joao@example.com\",\n  \"senha\": \"senha123\",\n  \"confirmarSenha\": \"senha123\",\n  \"cpf\": \"123.456.789-00\",\n  \"celular\": \"(11) 98765-4321\",\n  \"genero\": \"M\",\n  \"dataNascimento\": \"1990-05-15\",\n  \"cep\": \"12345-678\",\n  \"logradouro\": \"Rua A\",\n  \"numero\": \"123\",\n  \"bairro\": \"Centro\",\n  \"municipio\": \"São Paulo\",\n  \"estado\": \"SP\",\n  \"complemento\": \"Apto 101\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/usuarios",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "usuarios"]
            }
          }
        },
        {
          "name": "Atualizar usuário",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"João Silva Santos\",\n  \"email\": \"joao@example.com\",\n  \"senha\": \"senha123\",\n  \"confirmarSenha\": \"senha123\",\n  \"celular\": \"(11) 99999-8888\",\n  \"genero\": \"M\",\n  \"dataNascimento\": \"1990-05-15\",\n  \"cep\": \"54321-876\",\n  \"logradouro\": \"Rua B\",\n  \"numero\": \"456\",\n  \"bairro\": \"Vila Nova\",\n  \"municipio\": \"Rio de Janeiro\",\n  \"estado\": \"RJ\",\n  \"complemento\": \"Apto 202\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/usuarios/1",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "usuarios", "1"]
            }
          }
        },
        {
          "name": "Deletar usuário",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/api/v1/usuarios/1",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "usuarios", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "Itens",
      "item": [
        {
          "name": "Listar todos",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/items",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "items"]
            }
          }
        },
        {
          "name": "Obter por ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/items/1",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "items", "1"]
            }
          }
        },
